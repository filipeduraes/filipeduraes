<section id="contact" class="portfolio-section">
    <div class="portfolio-container">
        <div class="contact-box">
            <h2 class="contact-title">@Contact.Title</h2>
            <p class="contact-sub">@Contact.Sub</p>

            <div class="contact-actions d-flex flex-column flex-sm-row align-items-center justify-content-center gap-2 mb-4">
                <a href="mailto:filipehdduraes@gmail.com" class="btn-portfolio-primary d-inline-flex align-items-center gap-2">
                    <i class="bi bi-envelope"></i>
                    @Contact.EmailLabel
                </a>
                <a href="https://linkedin.com/in/filipeduraes" target="_blank" rel="noopener noreferrer"
                   class="btn-portfolio-outline d-inline-flex align-items-center gap-2">
                    <i class="bi bi-linkedin"></i>
                    LinkedIn
                </a>
                <a href="https://github.com/filipeduraes" target="_blank" rel="noopener noreferrer"
                   class="btn-portfolio-outline d-inline-flex align-items-center gap-2">
                    <i class="bi bi-github"></i>
                    GitHub
                </a>
                <a href="https://www.youtube.com/@@IdeaToGame" target="_blank" rel="noopener noreferrer"
                   class="btn-portfolio-outline d-inline-flex align-items-center gap-2">
                    <i class="bi bi-youtube"></i>
                    YouTube
                </a>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired]
    public Models.ContactContent Contact { get; set; } = default!;
}
