@implements IAsyncDisposable
@inject IJSRuntime JS

<nav class="portfolio-nav @(Scrolled ? "scrolled" : "")">
    <div class="portfolio-nav-inner container-fluid px-4 d-flex align-items-center justify-content-between mx-auto">
        <button type="button" class="portfolio-logo" @onclick='() => ScrollTo("about")'>FD.</button>

        <div class="d-none d-md-flex align-items-center gap-4">
            @for (var i = 0; i < Copy.Nav.Count; i++)
            {
                var index = i;
                <button type="button" class="portfolio-nav-link" @onclick="() => ScrollTo(Copy.NavIds[index])">
                    @Copy.Nav[index]
                </button>
            }

            <a href="https://www.youtube.com/@@IdeaToGame" target="_blank" rel="noopener noreferrer"
               class="portfolio-nav-icon" title="Idea.ToGame — YouTube">
                <i class="bi bi-youtube"></i>
            </a>

            <button type="button" class="portfolio-lang-btn" @onclick="OnToggleLanguage">
                @(Lang == "en" ? "PT" : "EN")
            </button>
        </div>

        <button type="button" class="portfolio-mobile-toggle d-md-none" @onclick="ToggleMenu" aria-label="Menu">
            <i class="bi @(MenuOpen ? "bi-x-lg" : "bi-list")"></i>
        </button>
    </div>

    @if (MenuOpen)
    {
        <div class="portfolio-mobile-menu d-md-none d-flex flex-column gap-3">
            @for (var i = 0; i < Copy.Nav.Count; i++)
            {
                var index = i;
                <button type="button" class="portfolio-nav-link" @onclick="() => ScrollTo(Copy.NavIds[index])">
                    @Copy.Nav[index]
                </button>
            }
            <a href="https://www.youtube.com/@@IdeaToGame" target="_blank" rel="noopener noreferrer"
               class="portfolio-nav-link d-flex align-items-center gap-2" style="color: var(--portfolio-rose);">
                <i class="bi bi-youtube"></i> Idea.ToGame
            </a>
            <button type="button" class="portfolio-lang-btn align-self-start" @onclick="ToggleLanguageAndCloseMenu">
                @(Lang == "en" ? "PT-BR" : "EN")
            </button>
        </div>
    }
</nav>

@code {
    [Parameter, EditorRequired]
    public string Lang { get; set; } = "en";

    [Parameter, EditorRequired]
    public Models.PortfolioCopy Copy { get; set; } = default!;

    [Parameter]
    public bool MenuOpen { get; set; }

    [Parameter]
    public bool Scrolled { get; set; }

    [Parameter]
    public EventCallback OnToggleLanguage { get; set; }

    [Parameter]
    public EventCallback<bool> MenuOpenChanged { get; set; }

    [Parameter]
    public EventCallback<bool> ScrolledChanged { get; set; }

    private DotNetObjectReference<PortfolioNav>? _dotNetRef;
    private IJSObjectReference? _scrollDisposable;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _scrollDisposable = await JS.InvokeAsync<IJSObjectReference>("portfolio.registerScroll", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnScroll(bool scrolled)
    {
        if (Scrolled != scrolled)
        {
            await ScrolledChanged.InvokeAsync(scrolled);
        }
    }

    private async Task ScrollTo(string id)
    {
        await JS.InvokeVoidAsync("portfolio.scrollTo", id);
        if (MenuOpen)
        {
            await MenuOpenChanged.InvokeAsync(false);
        }
    }

    private async Task ToggleMenu()
    {
        await MenuOpenChanged.InvokeAsync(!MenuOpen);
    }

    private async Task ToggleLanguageAndCloseMenu()
    {
        await OnToggleLanguage.InvokeAsync();
        await MenuOpenChanged.InvokeAsync(false);
    }

    public async ValueTask DisposeAsync()
    {
        if (_scrollDisposable is not null)
        {
            await _scrollDisposable.InvokeVoidAsync("dispose");
            await _scrollDisposable.DisposeAsync();
        }

        _dotNetRef?.Dispose();
    }
}
